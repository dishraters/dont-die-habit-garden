rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===== DDHG Users Collection =====
    match /ddhg_users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ===== DDHG Completions Collection =====
    // Records habit completions with RP earned
    match /ddhg_completions/{date}/{userId}/{completionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow list: if isOwner(userId);
    }

    // ===== Heartbeat State Collection =====
    // Public read (users need to see network state for pie chart)
    // Server-only write (via backend functions)
    match /heartbeat_state/{date} {
      allow read: if isSignedIn();
      allow create, update, delete: if false; // Server-only (Cloud Functions)
    }

    // ===== Ad Revenue Collection =====
    // For tracking advertiser spend
    match /adRevenue/{adId} {
      allow read: if isSignedIn();
      allow write: if false; // Server-only
    }

    // ===== Default: Deny All =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
